# Backend API Configuration
NEXT_PUBLIC_API_BASE_URL=http://localhost:8081/api
NEXT_PUBLIC_API_TIMEOUT=30000

# Authentication
NEXT_PUBLIC_JWT_TOKEN_KEY=admin_auth_token
NEXT_PUBLIC_JWT_REFRESH_TOKEN_KEY=admin_refresh_token
JWT_SECRET=your-jwt-secret-key-change-in-production

# Session Configuration
NEXT_PUBLIC_SESSION_TIMEOUT=3600000
NEXT_PUBLIC_TOKEN_REFRESH_INTERVAL=300000

# Environment
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_APP_NAME=Healthcare Market Research Admin

# Feature Flags
NEXT_PUBLIC_ENABLE_DARK_MODE=true
NEXT_PUBLIC_ENABLE_ANALYTICS=false

# Media/Upload Configuration
NEXT_PUBLIC_MAX_FILE_SIZE=10485760
NEXT_PUBLIC_ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,application/pdf

# Mock Data Toggle
NEXT_PUBLIC_USE_MOCK_DATA=false  # Set to false to use real API

# Preview Domain
NEXT_PUBLIC_PREVIEW_DOMAIN=http://localhost:3000  # Optional: Domain for external preview links (e.g., http://localhost:3000)